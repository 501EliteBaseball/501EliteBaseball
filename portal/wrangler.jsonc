{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "501elite-os",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-14",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "os.501elitebaseball.com",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
